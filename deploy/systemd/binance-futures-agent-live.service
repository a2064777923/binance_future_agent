[Unit]
Description=Binance Futures Agent automated one-cycle trading run
Documentation=file:/opt/binance-futures-agent/app/docs/deployment.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/binance-futures-agent/app
EnvironmentFile=/etc/binance-futures-agent/env
ExecStart=/opt/binance-futures-agent/.venv/bin/python -m bfa.cli agent run-once --env-file /etc/binance-futures-agent/env --db /opt/binance-futures-agent/data/agent.sqlite --journal /opt/binance-futures-agent/logs/ai-decisions.jsonl --top-n 20
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/binance-futures-agent /etc/binance-futures-agent
