[Unit]
Description=Binance Futures Agent SQLite/raw-feed retention maintenance
Documentation=file:/opt/binance-futures-agent/app/docs/deployment.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/binance-futures-agent/app
EnvironmentFile=/etc/binance-futures-agent/env
ExecStart=/opt/binance-futures-agent/.venv/bin/python -m bfa.cli ops db-maintenance --env-file /etc/binance-futures-agent/env --db /opt/binance-futures-agent/data/agent.sqlite --execute --batch-size 5000 --max-delete-rows 25000 --clean-raw-feed
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/binance-futures-agent/data /opt/binance-futures-agent/runtime /opt/binance-futures-agent/logs
