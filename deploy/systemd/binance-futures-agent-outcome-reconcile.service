[Unit]
Description=Binance Futures Agent closed-trade outcome reconciliation
Documentation=file:/opt/binance-futures-agent/app/docs/deployment.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/binance-futures-agent/app
EnvironmentFile=/etc/binance-futures-agent/env
ExecStart=/opt/binance-futures-agent/.venv/bin/python -m bfa.cli ops reconcile-outcomes --env-file /etc/binance-futures-agent/env --db /opt/binance-futures-agent/data/agent.sqlite --persist-closed --lookback-hours 72 --limit 500 --summary-only
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/binance-futures-agent/data
